# Dependencies
node_modules/

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Local config overrides
config.local.json

# Dashboard build output
dashboard/dist/

# Yarn (using node-modules linker, no need to check in state)
dashboard/.yarn/install-state.gz

# Package lock (using Yarn, not npm)
dashboard/package-lock.json

# Runtime state (generated by the server)
.hub-runtime/

# Job progress files (runtime artifacts, project-specific)
notes/jobs/
notes/swarm/

# Plans (project-specific work-in-progress)
plans/

# Agent runtime
.agents/

# Dispatch loop artifacts
.dispatch/

# Claude local settings (personal permissions, not committed)
.claude/settings.local.json

# Claude references (strategy docs, not committed)
.claude/references/

# Only keep selected skills (cannot use .claude/skills/ alone — negations do not
# re-include files inside an ignored parent directory)
.claude/skills/*
!.claude/skills/dispatch/
!.claude/skills/dispatch/**
!.claude/skills/add-repo/
!.claude/skills/add-repo/**
!.claude/skills/done/
!.claude/skills/done/**

# Hide personal notes
notes/