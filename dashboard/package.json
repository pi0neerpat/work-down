{
  "name": "dispatch-dashboard",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "yarn@4.9.1",
  "scripts": {
    "postinstall": "cd node_modules/node-pty && npx node-gyp rebuild 2>/dev/null || true",
    "dev": "concurrently \"node --watch server.js\" \"vite\"",
